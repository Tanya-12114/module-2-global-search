# Base URL of the standalone Global Search API (see the sibling `backend/`
# project — Hono + Prisma, deployed to Cloudflare Workers).
#
# Local dev default matches `wrangler dev`'s default port, so this is
# optional locally. Required in production — set it to your deployed
# Worker's URL (or custom domain) in your hosting platform's environment
# variables.
NEXT_PUBLIC_API_BASE_URL="http://localhost:8787"
